# Optional overrides for iem-web-services-podman.service
# Copy to /etc/iem-web-services/iemws.env on the host.

# Podman secret name that provides a libpq passfile at /run/secrets/pgpass.
PGPASS_SECRET=iemws-pgpass
# File ownership for mounted pgpass secret inside the container.
# Defaults match mambaorg/micromamba image user.
PGPASS_UID=57439
PGPASS_GID=57439

# Podman publish target. Use 127.0.0.1 for local reverse proxy,
# or 0.0.0.0 / specific interface IP for external proxying.
PUBLISH_HOST=127.0.0.1
PUBLISH_PORT=8000

# Database connectivity
# Use per-database host settings for sharded deployments.
# Examples:
# IEMWS_DBHOST_MESOSITE=iemdb-mesosite.local
# IEMWS_DBHOST_IEM=iemdb-iem.local
# IEMWS_DBHOST_POSTGIS=iemdb-postgis.local
# IEMWS_DBHOST_ASOS=iemdb-asos.local
#
# Global fallback user can still be set if desired.
IEMWS_DBUSER=mesonet

# Set to 1 to disable telemetry writes.
IEMWS_DISABLE_TELEMETRY=0

# Container runtime tuning (optional)
WORKERS=6
MAX_REQUESTS=2000

# Optional image override if you want to pin a digest or tag.
IMAGE=ghcr.io/akrherz/iem-web-services:latest
